{
  "name": "@shapp/devtool",
  "version": "1.2.3",
  "private": true,
  "description": "Shapp DevTool — 本地轻应用调试工具",
  "main": "out/main/index.js",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "better-sqlite3",
      "esbuild",
      "sharp"
    ]
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack:win": "powershell -ExecutionPolicy Bypass -File ./scripts/prepare-deno-win.ps1 && pnpm run build && electron-builder --win",
    "pack:mac": "pnpm run build && electron-builder --mac",
    "pack:linux": "pnpm run build && electron-builder --linux",
    "pack:all": "pnpm run build && electron-builder --win --mac --linux"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.15.10",
    "@types/react-syntax-highlighter": "^15.5.13",
    "better-sqlite3": "^11.9.1",
    "chokidar": "^4.0.3",
    "electron-updater": "^6.3.0",
    "fflate": "^0.8.3",
    "isomorphic-git": "^1.38.5",
    "qrcode": "^1.5.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.35.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.10",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.0.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "zustand": "^5.0.3"
  }
}
